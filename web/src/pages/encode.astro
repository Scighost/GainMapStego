---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="合成" toolPage>
  <div class="tool-page">

    <!-- ── Sidebar ─────────────────────────────────────── -->
    <aside class="sidebar">
      <h2>合成选项</h2>

      <hr />

      <div class="section-label">图像</div>

      <div class="form-row">
        <div class="form-label">
          图像质量
          <span id="v-quality">90</span>
        </div>
        <input id="image-quality" type="range" min="1" max="100" value="90" />
      </div>

      <div class="form-row">
        <div class="form-label">
          输出分辨率
          <span id="v-scale">100%</span>
        </div>
        <input id="image-scale" type="range" min="0.1" max="1" step="0.01" value="1" />
      </div>

      <div class="form-trio">
        <div class="form-trio-item">
          <div class="form-label">背景色</div>
          <input id="bg-color" type="color" value="#ffffff" class="color-swatch" />
        </div>
        <div class="form-trio-item">
          <div class="form-label">完整展示</div>
          <div class="seg-ctrl">
            <label class="seg-opt"><input type="radio" name="target-display" value="base" checked /><span>表图</span></label>
            <label class="seg-opt"><input type="radio" name="target-display" value="alternate" /><span>里图</span></label>
          </div>
        </div>
        <div class="form-trio-item">
          <div class="form-label">缩放模式</div>
          <div class="seg-ctrl">
            <label class="seg-opt"><input type="radio" name="scale-mode" value="fit" checked /><span>适应</span></label>
            <label class="seg-opt"><input type="radio" name="scale-mode" value="fill" /><span>填充</span></label>
          </div>
        </div>
      </div>

      <hr />

      <div class="section-label">增益图参数</div>

      <div class="form-row">
        <div class="form-label">
          Gamma
          <span id="v-gamma">1.0</span>
        </div>
        <input id="gainmap-gamma" type="range" min="0.1" max="2" step="0.1" value="1" />
      </div>

      <div class="form-row">
        <div class="form-label">
          Offset
          <span id="v-offset">1.0</span>
        </div>
        <input id="gainmap-offset" type="range" min="0.1" max="2" step="0.1" value="1" />
      </div>

      <hr />

      <div class="btn-group">
        <button id="btn-encode" class="btn-primary">合成</button>
        <button id="btn-cancel" style="display:none">取消</button>
        <button id="btn-reset">制作新图片</button>
      </div>

      <div id="encode-status" class="status-bar"></div>

      <div id="result-meta" class="meta-dl-wrap" style="display:none"></div>

      <input id="file-base" type="file" accept="image/*" hidden />
      <input id="file-alt"  type="file" accept="image/*" hidden />
    </aside>

    <!-- ── Workspace ───────────────────────────────────── -->
    <section class="workspace">
      <figure class="drop-zone" id="zone-base">
        <figcaption>表图<span class="zone-tag opt">可选</span><span class="zone-dim" id="dim-base"></span></figcaption>
        <div class="img-wrap">
          <img id="preview-base" alt="表图" />
          <div class="zone-placeholder" id="ph-base">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/>
              <polyline points="21 15 16 10 5 21"/>
            </svg>
            <strong>点击或拖入图片</strong>
          </div>
        </div>
      </figure>

      <figure class="drop-zone" id="zone-alt">
        <figcaption>里图<span class="zone-tag req">必需</span><span class="zone-dim" id="dim-alt"></span></figcaption>
        <div class="img-wrap">
          <img id="preview-alt" alt="里图" />
          <div class="zone-placeholder" id="ph-alt">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/>
              <polyline points="21 15 16 10 5 21"/>
            </svg>
            <strong>点击或拖入图片</strong>
          </div>
        </div>
      </figure>

      <div class="result-box">
        <div class="result-toolbar">
          <button id="result-show-hdr"    class="active">预览</button>
          <button id="result-show-base">表图</button>
          <button id="result-show-alt">里图</button>
          <button id="result-show-gainmap">增益图</button>
          <button id="btn-save-hdr" class="save-btn" disabled title="保存增益图 JPG">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/>
              <polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/>
            </svg>
            保存
          </button>
        </div>
        <div class="img-wrap">
          <img id="preview-result" alt="结果预览" />
        </div>
      </div>
    </section>

  </div>
</BaseLayout>

<script>
import { buildGainMap, composeBaseAndAlternate } from '../lib/image-processing.js';
import { createIsoMetadata, packGainmapJpeg } from '../lib/iso21496.js';
import { blobToImage, canvasToJpegBlob, downloadBlob, fileSizeText } from '../lib/utils.js';
import { openLightbox } from '../lib/lightbox.js';

/* ── State ─────────────────────────────────────────────── */
interface Encoded {
  baseCanvas: HTMLCanvasElement;
  alternateCanvas: HTMLCanvasElement;
  gainMapCanvas: HTMLCanvasElement;
  gainmapHdrBlob: Blob;
  baseBlob: Blob;
  gainBlob: Blob;
  altBlob: Blob;
}

let baseBitmap: ImageBitmap | null = null;
let altBitmap:  ImageBitmap | null = null;
let encoded:    Encoded | null     = null;

/* ── Element refs ──────────────────────────────────────── */
const $  = (id: string) => document.getElementById(id)!;
const $i = (id: string) => $( id) as HTMLInputElement;

const fileBase    = $i('file-base');
const fileAlt     = $i('file-alt');
const previewBase = $('preview-base') as HTMLImageElement;
const previewAlt  = $('preview-alt')  as HTMLImageElement;
const previewResult = $('preview-result') as HTMLImageElement;
let _hdrObjectUrl: string | null = null;
const resultMeta  = $('result-meta') as HTMLElement;
const statusEl    = $('encode-status');
const phBase      = $('ph-base');
const phAlt       = $('ph-alt');

/* ── Meta row helper ───────────────────────────────────────── */
const row = (k: string, v: string) =>
  `<div class="meta-dl-row"><span class="mk">${k}</span><span class="mv">${v}</span></div>`;

/* ── Label sync ────────────────────────────────────────── */
function syncLabels() {
  $('v-quality').textContent = $i('image-quality').value;
  $('v-scale').textContent   = `${Math.round(+$i('image-scale').value * 100)}%`;
  $('v-gamma').textContent   = (+$i('gainmap-gamma').value).toFixed(1);
  $('v-offset').textContent  = (+$i('gainmap-offset').value).toFixed(1);
}
['image-quality','image-scale','gainmap-gamma','gainmap-offset'].forEach(id =>
  $(id).addEventListener('input', syncLabels)
);
syncLabels();

/* ── Save button ───────────────────────────────────────── */
const btnSaveHdr  = $('btn-save-hdr') as HTMLButtonElement;
const btnEncode   = $('btn-encode')   as HTMLButtonElement;
const btnCancel   = $('btn-cancel')   as HTMLButtonElement;
function setExports(on: boolean) { btnSaveHdr.disabled = !on; }
setExports(false);

let _isEncoding  = false;
let _cancelled   = false;
function setEncoding(on: boolean) {
  _isEncoding = on;
  if (on) {
    btnEncode.textContent = '合成中…';
    btnEncode.classList.add('btn-running');
    btnEncode.disabled = true;
    btnCancel.style.display = '';
  } else {
    btnEncode.textContent = '合成';
    btnEncode.classList.remove('btn-running');
    btnEncode.disabled = false;
    btnCancel.style.display = 'none';
    _cancelled = false;
  }
}
btnCancel.addEventListener('click', () => { _cancelled = true; setEncoding(false); statusEl.textContent = '已取消'; });

/* ── Image loading ─────────────────────────────────────── */
async function loadImage(file: File, target: 'base' | 'alt') {
  const bm  = await blobToImage(file);
  const url = URL.createObjectURL(file);
  if (target === 'base') {
    baseBitmap       = bm;
    previewBase.src  = url;
    phBase.style.display = 'none';
    ($('dim-base') as HTMLElement).textContent = `${bm.width} × ${bm.height}`;
  } else {
    altBitmap       = bm;
    previewAlt.src  = url;
    phAlt.style.display = 'none';
    ($('dim-alt') as HTMLElement).textContent = `${bm.width} × ${bm.height}`;
  }
}

/* ── Drop zones ────────────────────────────────────────── */
function bindDrop(zoneId: string, target: 'base' | 'alt') {
  const zone = $(zoneId);
  zone.addEventListener('dragover', e => { e.preventDefault(); zone.classList.add('drag-over'); });
  zone.addEventListener('dragleave', () => zone.classList.remove('drag-over'));
  zone.addEventListener('drop', async e => {
    e.preventDefault(); zone.classList.remove('drag-over');
    const f = (e as DragEvent).dataTransfer?.files?.[0];
    if (f) await loadImage(f, target);
  });
  zone.addEventListener('click', () => (target === 'base' ? fileBase : fileAlt).click());
}
bindDrop('zone-base', 'base');
bindDrop('zone-alt',  'alt');

fileBase.addEventListener('change', async e => {
  const f = (e.target as HTMLInputElement).files?.[0];
  if (f) await loadImage(f, 'base');
});
fileAlt.addEventListener('change', async e => {
  const f = (e.target as HTMLInputElement).files?.[0];
  if (f) await loadImage(f, 'alt');
});

$('btn-reset').addEventListener('click', () => {
  baseBitmap = altBitmap = encoded = null;
  previewBase.removeAttribute('src');
  previewAlt.removeAttribute('src');
  previewResult.removeAttribute('src');
  if (_hdrObjectUrl) { URL.revokeObjectURL(_hdrObjectUrl); _hdrObjectUrl = null; }
  resultMeta.innerHTML = '';
  resultMeta.style.display = 'none';
  statusEl.textContent     = '';
  phBase.style.display     = '';
  phAlt.style.display      = '';
  ($('dim-base') as HTMLElement).textContent = '';
  ($('dim-alt') as HTMLElement).textContent  = '';
  setExports(false);
});

/* ── Result preview toggle ─────────────────────────────── */
function showResult(kind: 'base' | 'alternate' | 'gainmap' | 'hdr') {
  if (!encoded) return;
  if (kind === 'hdr') {
    previewResult.src = _hdrObjectUrl!;
  } else {
    const map = { base: encoded.baseCanvas, alternate: encoded.alternateCanvas, gainmap: encoded.gainMapCanvas };
    previewResult.src = map[kind].toDataURL('image/png');
  }
  $('result-show-base').classList.toggle('active',    kind === 'base');
  $('result-show-alt').classList.toggle('active',     kind === 'alternate');
  $('result-show-gainmap').classList.toggle('active', kind === 'gainmap');
  $('result-show-hdr').classList.toggle('active',     kind === 'hdr');
}
$('result-show-base').addEventListener('click',    () => showResult('base'));
$('result-show-alt').addEventListener('click',     () => showResult('alternate'));
$('result-show-gainmap').addEventListener('click', () => showResult('gainmap'));
$('result-show-hdr').addEventListener('click',     () => showResult('hdr'));

// 点击结果图片打开灯箱
previewResult.style.cursor = 'zoom-in';
previewResult.addEventListener('click', () => {
  if (!encoded || !previewResult.getAttribute('src')) return;
  // 以当前显示的 tab 为准，预览该张图
  const activeBtn = document.querySelector('.result-toolbar button.active') as HTMLElement;
  const labelMap: Record<string, string> = {
    'result-show-hdr':     '预览',
    'result-show-base':    '表图',
    'result-show-alt':     '里图',
    'result-show-gainmap': '增益图',
  };
  const label = activeBtn ? (labelMap[activeBtn.id] ?? '预览') : '预览';
  openLightbox({ src: previewResult.src, label });
});

/* ── Encode ────────────────────────────────────────────── */
$('btn-encode').addEventListener('click', async () => {
  if (_isEncoding) return;
  if (!altBitmap) {
    statusEl.textContent = '请先拖入或选择里图（必需项）';
    statusEl.className   = 'status-bar error';
    return;
  }
  setEncoding(true);
  statusEl.textContent = '合成中…';
  statusEl.className   = 'status-bar';
  try {
    const gamma  = +$i('gainmap-gamma').value;
    const offset = +$i('gainmap-offset').value;

    const { baseCanvas, alternateCanvas, outW, outH } = composeBaseAndAlternate({
      baseBitmap,
      alternateBitmap: altBitmap,
      targetDisplay: (document.querySelector('input[name="target-display"]:checked') as HTMLInputElement)?.value ?? 'base',
      imageScale: +$i('image-scale').value,
      scaleMode: (document.querySelector('input[name="scale-mode"]:checked') as HTMLInputElement)?.value ?? 'fit',
      backgroundColor: $i('bg-color').value,
    });
    if (_cancelled) return;

    const gain = buildGainMap({ baseCanvas, alternateCanvas, gamma, offset });
    const meta = createIsoMetadata({
      gamma: [gamma, gamma, gamma],
      offsetSdr: [offset, offset, offset],
      offsetHdr: [offset, offset, offset],
      minContentBoost: gain.minContentBoost,
      maxContentBoost: gain.maxContentBoost,
      hdrCapacityMin: 1,
      hdrCapacityMax: Math.max(...gain.maxContentBoost, 1.0001),
      useBaseColorSpace: 1,
    });
    if (_cancelled) return;

    const quality = +$i('image-quality').value;
    const [baseBlob, gainBlob] = await Promise.all([
      canvasToJpegBlob(baseCanvas, quality),
      canvasToJpegBlob(gain.gainMapCanvas, quality),
    ]);
    if (_cancelled) return;

    const baseBytes   = new Uint8Array(await baseBlob.arrayBuffer());
    const gainBytes   = new Uint8Array(await gainBlob.arrayBuffer());
    const hdrBytes    = packGainmapJpeg({ baseJpegBytes: baseBytes, gainmapJpegBytes: gainBytes, metadata: meta });
    const altBlob     = await canvasToJpegBlob(alternateCanvas, quality);
    if (_cancelled) return;

    encoded = {
      baseCanvas, alternateCanvas, gainMapCanvas: gain.gainMapCanvas,
      gainmapHdrBlob: new Blob([hdrBytes], { type: 'image/jpeg' }),
      baseBlob, gainBlob, altBlob,
    };

    resultMeta.innerHTML = [
      row('分辨率', `${outW} × ${outH}`),
      row('基础图', fileSizeText(baseBlob.size)),
      row('增益图', fileSizeText(gainBlob.size)),
      row('合成图', fileSizeText(encoded.gainmapHdrBlob.size)),
      `<hr class="meta-dl-sep" />`,
      row('minBoost', gain.minContentBoost.map((x: number) => x.toFixed(3)).join(', ')),
      row('maxBoost', gain.maxContentBoost.map((x: number) => x.toFixed(3)).join(', ')),
    ].join('');
    resultMeta.style.display = '';

    setExports(true);
    if (_hdrObjectUrl) URL.revokeObjectURL(_hdrObjectUrl);
    _hdrObjectUrl = URL.createObjectURL(encoded.gainmapHdrBlob);
    showResult('hdr');
    statusEl.textContent = '✓ 合成完成';
    statusEl.className   = 'status-bar ok';
  } catch (err: any) {
    if (!_cancelled) {
      statusEl.textContent = `合成失败：${err?.message ?? err}`;
      statusEl.className   = 'status-bar error';
    }
  } finally {
    setEncoding(false);
  }
});

/* ── Save ──────────────────────────────────────────────── */
btnSaveHdr.addEventListener('click', () => encoded && downloadBlob(encoded.gainmapHdrBlob, `stego_${Math.floor(Date.now()/1000)}.jpg`));
</script>

<style>
  /* form-trio: 3 items side-by-side (color swatch + 2 seg-ctrls) */
  .form-trio {
    display: grid;
    grid-template-columns: auto 1fr 1fr;
    gap: 6px 10px;
    align-items: end;
  }
  .form-trio-item {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .color-swatch {
    width: 36px;
    height: 28px;
    padding: 2px;
    border: 1px solid var(--border);
    border-radius: 6px;
    cursor: pointer;
    background: var(--bg-input);
  }
  /* result toolbar save button */
  .result-toolbar .save-btn {
    margin-left: auto;
    display: flex;
    align-items: center;
    gap: 0.3rem;
    padding: 0.2rem 0.65rem;
    font-size: 0.8rem;
    background: var(--accent);
    color: #fff;
    border: 1px solid var(--accent);
    border-radius: 4px;
    cursor: pointer;
    transition: background 0.15s;
  }
  .result-toolbar .save-btn:disabled {
    opacity: 0.35;
    cursor: not-allowed;
  }
  .result-toolbar .save-btn:not(:disabled):hover {
    background: var(--accent-hv, var(--accent));
    border-color: var(--accent-hv, var(--accent));
  }
  img:not([src]),
  img[src=""] {
    display: none;
  }
</style>
